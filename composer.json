{
    "name": "eventio/php-api-client",
    "version": "1.0.3",
    "description": "A typed PHP client for the EventIO API",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EventIO\\ApiClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EventIO\\ApiClient\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}